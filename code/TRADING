# ============================================================
# DOMAIN 1: QUANTITATIVE / SYSTEMATIC TRADING
# Simple moving average crossover backtest
# WARNING: This will look more profitable than it is in reality.
# No transaction costs, slippage, or survivorship bias included.
# ============================================================

import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

def backtest_sma_crossover(prices: pd.Series, short_window=20, long_window=50):
    """
    Buy when short MA crosses above long MA. Sell when it crosses below.
    Returns a DataFrame with signals and cumulative returns.
    """
    df = pd.DataFrame({'price': prices})
    df['sma_short'] = df['price'].rolling(short_window).mean()
    df['sma_long']  = df['price'].rolling(long_window).mean()

    # Signal: 1 = long, 0 = flat
    df['signal'] = 0
    df.loc[df['sma_short'] > df['sma_long'], 'signal'] = 1

    # Daily returns
    df['market_return']   = df['price'].pct_change()
    df['strategy_return'] = df['signal'].shift(1) * df['market_return']  # shift(1) avoids look-ahead bias

    df['cumulative_market']   = (1 + df['market_return']).cumprod()
    df['cumulative_strategy'] = (1 + df['strategy_return']).cumprod()

    # Basic stats
    n_trades = df['signal'].diff().abs().sum()
    sharpe = (df['strategy_return'].mean() / df['strategy_return'].std()) * np.sqrt(252)
    total_return = df['cumulative_strategy'].iloc[-1] - 1

    print(f"[SMA Crossover Backtest]")
    print(f"  Total return (strategy): {total_return:.2%}")
    print(f"  Annualized Sharpe:       {sharpe:.2f}")
    print(f"  Number of signal flips:  {int(n_trades)}")
    print(f"  NOTE: No transaction costs applied. Real returns will be lower.\n")

    return df

# --- Demo with synthetic price data ---
np.random.seed(42)
price_series = pd.Series(100 * np.cumprod(1 + np.random.normal(0.0003, 0.01, 500)))
backtest_sma_crossover(price_series)


