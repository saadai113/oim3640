print(f"\n  Market Buy 250 shares → Filled: {filled}, Avg Price: {avg:.4f}")
print(f"  Best Ask after fill: {book.best_ask()}")
print(f"  NOTE: Real books handle order IDs, cancels, and partial fills at nanosecond speed.\n")


