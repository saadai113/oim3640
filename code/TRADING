# DOMAIN 4: MARKET MICROSTRUCTURE — Order Book Simulation
# Real order books operate in microseconds with co-located servers.
# This is a conceptual model, not a latency-sensitive implementation.
# ============================================================

from collections import defaultdict
import heapq

class OrderBook:
    """
    Simplified limit order book (LOB).
    Bids: max-heap (negate prices). Asks: min-heap.
    """

    def __init__(self):
        self.bids = []  # max-heap: store as negative prices
        self.asks = []  # min-heap
        self.bid_sizes = defaultdict(float)
        self.ask_sizes = defaultdict(float)

    def add_limit_order(self, side: str, price: float, size: float):
        if side == 'bid':
            heapq.heappush(self.bids, -price)
            self.bid_sizes[price] += size
        elif side == 'ask':
            heapq.heappush(self.asks, price)
            self.ask_sizes[price] += size

    def best_bid(self):
        while self.bids and self.bid_sizes[-self.bids[0]] <= 0:
            heapq.heappop(self.bids)
        return -self.bids[0] if self.bids else None

    def best_ask(self):
        while self.asks and self.ask_sizes[self.asks[0]] <= 0:
            heapq.heappop(self.asks)
        return self.asks[0] if self.asks else None

    def mid_price(self):
        bb, ba = self.best_bid(), self.best_ask()
        if bb and ba:
            return (bb + ba) / 2
        return None

    def bid_ask_spread(self):
        bb, ba = self.best_bid(), self.best_ask()
        if bb and ba:
            return ba - bb
        return None

    def market_order(self, side: str, size: float):
        """Execute a market order, consuming liquidity from the book."""
        filled, cost = 0, 0
        if side == 'buy':
            while size > 0 and self.asks:
                best = self.best_ask()
                if best is None:
                    break
                available = self.ask_sizes[best]
                fill = min(size, available)
                cost += fill * best
                self.ask_sizes[best] -= fill
                filled += fill
                size -= fill
        elif side == 'sell':
            while size > 0 and self.bids:
                best = self.best_bid()
                if best is None:
                    break
                available = self.bid_sizes[best]
                fill = min(size, available)
                cost += fill * best
                self.bid_sizes[best] -= fill
                filled += fill
                size -= fill
        avg_price = cost / filled if filled > 0 else None
        return filled, avg_price

# --- Demo ---
book = OrderBook()
for price, size in [(99.5, 100), (99.0, 200), (98.5, 150)]:
    book.add_limit_order('bid', price, size)
for price, size in [(100.5, 100), (101.0, 200), (101.5, 150)]:
    book.add_limit_order('ask', price, size)

print(f"[Order Book State]")
print(f"  Best Bid:  {book.best_bid()}")
print(f"  Best Ask:  {book.best_ask()}")
print(f"  Mid Price: {book.mid_price()}")
print(f"  Spread:    {book.bid_ask_spread()}")

