# DOMAIN 2: RISK MANAGEMENT — Value at Risk (VaR)
# Historical simulation and parametric VaR
# VaR tells you the loss not exceeded at a confidence level.
# It says NOTHING about how bad losses are beyond that threshold.
# ============================================================

def compute_var(returns: pd.Series, confidence=0.95):
    """
    Historical VaR and Parametric (Gaussian) VaR at given confidence level.
    
    Limitation: Both assume history repeats and returns are IID.
    Historical VaR breaks in regime changes. Parametric VaR underestimates tail risk.
    """
    returns = returns.dropna()

    # Historical VaR
    hist_var = -np.percentile(returns, (1 - confidence) * 100)

    # Parametric VaR (assumes normality — often wrong in practice)
    from scipy.stats import norm
    mu, sigma = returns.mean(), returns.std()
    param_var = -(mu + norm.ppf(1 - confidence) * sigma)

    # CVaR / Expected Shortfall — average loss beyond VaR
    cvar = -returns[returns <= -hist_var].mean()

    print(f"[Value at Risk — {confidence:.0%} confidence]")
    print(f"  Historical VaR:  {hist_var:.4f}  ({hist_var*100:.2f}% of position)")
    print(f"  Parametric VaR:  {param_var:.4f}  ({param_var*100:.2f}% of position)")
    print(f"  CVaR (ES):       {cvar:.4f}  (avg loss in worst {(1-confidence)*100:.0f}% of days)")
    print(f"  NOTE: Parametric VaR understates tail risk for fat-tailed assets.\n")

    return hist_var, param_var, cvar

# --- Demo ---
daily_returns = pd.Series(np.random.normal(0.0005, 0.015, 1000))
compute_var(daily_returns, confidence=0.95)
compute_var(daily_returns, confidence=0.99)


# ============================================================
# DOMAIN 3: DERIVATIVES PRICING — Black-Scholes + Greeks
# BSM assumes constant vol, no jumps, frictionless markets.
# These assumptions break in practice. Use as a baseline only.
# ============================================================

from scipy.stats import norm as _norm
import math

def black_scholes(S, K, T, r, sigma, option_type='call'):
    """
    Black-Scholes-Merton option pricing.
    
    S     : Current stock price
    K     : Strike price
    T     : Time to expiry in years
    r     : Risk-free rate (annual)
    sigma : Implied volatility (annual)
    
    Returns: (price, delta, gamma, vega, theta)
    """
    if T <= 0:
        # Intrinsic value at expiry
        intrinsic = max(S - K, 0) if option_type == 'call' else max(K - S, 0)
        return intrinsic, None, None, None, None

    d1 = (math.log(S / K) + (r + 0.5 * sigma**2) * T) / (sigma * math.sqrt(T))
    d2 = d1 - sigma * math.sqrt(T)

    if option_type == 'call':
        price = S * _norm.cdf(d1) - K * math.exp(-r * T) * _norm.cdf(d2)
        delta = _norm.cdf(d1)
    else:
        price = K * math.exp(-r * T) * _norm.cdf(-d2) - S * _norm.cdf(-d1)
        delta = _norm.cdf(d1) - 1

    gamma = _norm.pdf(d1) / (S * sigma * math.sqrt(T))
    vega  = S * _norm.pdf(d1) * math.sqrt(T) / 100          # per 1% vol move
    theta = (-(S * _norm.pdf(d1) * sigma) / (2 * math.sqrt(T))
             - r * K * math.exp(-r * T) * _norm.cdf(d2)) / 365  # per day

    return price, delta, gamma, vega, theta

# --- Demo ---
S, K, T, r, sigma = 100, 105, 0.5, 0.05, 0.20
price, delta, gamma, vega, theta = black_scholes(S, K, T, r, sigma, 'call')

print(f"[Black-Scholes Call Option]")
print(f"  S={S}, K={K}, T={T}y, r={r:.0%}, σ={sigma:.0%}")
print(f"  Price:  ${price:.4f}")
print(f"  Delta:  {delta:.4f}  ($ change per $1 move in S)")
print(f"  Gamma:  {gamma:.4f}  (Delta change per $1 move in S)")
print(f"  Vega:   {vega:.4f}   ($ change per 1% vol move)")
print(f"  Theta:  {theta:.4f}  ($ decay per day)")
print(f"  NOTE: Vol smile/skew means real-world pricing deviates from BSM.\n")


