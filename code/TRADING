# DOMAIN 5: FIXED INCOME / RATES — Yield Curve & Duration
# Bond math is deceptively simple here but breaks with embedded
# options, callable bonds, or floating-rate instruments.
# ============================================================

def bond_price(face: float, coupon_rate: float, ytm: float, periods: int, freq=2):
    """
    Price a fixed-rate bond given yield to maturity.
    
    face        : Face/par value
    coupon_rate : Annual coupon rate
    ytm         : Annual yield to maturity
    periods     : Total coupon periods remaining
    freq        : Coupon payments per year (2 = semi-annual)
    """
    coupon = face * coupon_rate / freq
    ytm_per = ytm / freq
    
    # PV of coupons + PV of face
    pv_coupons = coupon * (1 - (1 + ytm_per)**(-periods)) / ytm_per
    pv_face = face / (1 + ytm_per)**periods
    return pv_coupons + pv_face

def modified_duration(face, coupon_rate, ytm, periods, freq=2):
    """
    Modified Duration: % price change per 1% change in yield.
    Approximation breaks down for large yield moves (convexity effect).
    """
    dy = 0.0001  # 1 basis point
    p_up   = bond_price(face, coupon_rate, ytm + dy, periods, freq)
    p_down = bond_price(face, coupon_rate, ytm - dy, periods, freq)
    p      = bond_price(face, coupon_rate, ytm,      periods, freq)
    
    mod_dur = -(p_up - p_down) / (2 * dy * p)
    return mod_dur

def build_yield_curve(maturities, yields):
    """
    Simple linear interpolation of a yield curve.
    Real curves use cubic splines or Nelson-Siegel parametrization.
    """
    from numpy import interp
    interp_maturities = np.linspace(min(maturities), max(maturities), 100)
    interp_yields = interp(interp_maturities, maturities, yields)
    return interp_maturities, interp_yields

